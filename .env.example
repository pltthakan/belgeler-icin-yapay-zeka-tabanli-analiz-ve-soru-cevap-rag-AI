POSTGRES_DB=ragdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
JWT_SECRET=dev-secret-key-change-this-value-minimum-32-chars
AI_SERVICE_BASE_URL=http://ai-service:5000

# İsteğe bağlı: kaynaklara dayalı, doğal dilde cevap üretimi için Ollama.
# Docker Desktop (macOS/Windows) kullanırken Ollama'nın host adresi:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=30
