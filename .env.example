POSTGRES_DB=ragdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
JWT_SECRET=dev-secret-key-change-this-value-minimum-32-chars
AI_SERVICE_BASE_URL=http://ai-service:5000
DOCUMENT_PROCESSING_RETRY_DELAY_MS=30000
DOCUMENT_PROCESSING_MAX_RETRIES=3

# İsteğe bağlı: kaynaklara dayalı, doğal dilde cevap üretimi için Ollama.
# Docker Desktop (macOS/Windows) kullanırken Ollama'nın host adresi:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=60

# En iyi kaynak parçası bu cosine similarity skorunun altındaysa Ollama/QA
# çağrılmaz; kullanıcıya belgeden yeterli eşleşme bulunamadığı söylenir.
RAG_MIN_RETRIEVAL_SCORE=0.10
